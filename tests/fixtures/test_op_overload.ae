// test_op_overload.ae — operator overloading with struct types
import "std/test"

struct Vector {
    x: int
    y: int
}

// Operator overload methods use op_<symbol> naming
func op_+(self: Vector, other: Vector): Vector {
    let result: Vector
    result.x = self.x + other.x
    result.y = self.y + other.y
    return result
}

func op_-(self: Vector, other: Vector): Vector {
    let result: Vector
    result.x = self.x - other.x
    result.y = self.y - other.y
    return result
}

func op_*(self: Vector, scalar: int): Vector {
    let result: Vector
    result.x = self.x * scalar
    result.y = self.y * scalar
    return result
}

func op_==(self: Vector, other: Vector): bool {
    return self.x == other.x and self.y == other.y
}

// Unicode custom operator: ⌛ adds two ints
func op_⌛(a: int, b: int): int {
    return a + b
}

@test
func test_op_add(): void {
    let a: Vector
    a.x = 1
    a.y = 2
    let b: Vector
    b.x = 3
    b.y = 4
    let c: Vector = a + b
    assertTrue(c.x == 4, "op_+: c.x == 4")
    assertTrue(c.y == 6, "op_+: c.y == 6")
}

@test
func test_op_sub(): void {
    let a: Vector
    a.x = 5
    a.y = 7
    let b: Vector
    b.x = 2
    b.y = 3
    let c: Vector = a - b
    assertTrue(c.x == 3, "op_-: c.x == 3")
    assertTrue(c.y == 4, "op_-: c.y == 4")
}

@test
func test_op_mul(): void {
    let a: Vector
    a.x = 2
    a.y = 3
    let c: Vector = a * 3
    assertTrue(c.x == 6, "op_*: c.x == 6")
    assertTrue(c.y == 9, "op_*: c.y == 9")
}

@test
func test_op_eq(): void {
    let a: Vector
    a.x = 1
    a.y = 2
    let b: Vector
    b.x = 1
    b.y = 2
    let c: Vector
    c.x = 1
    c.y = 3
    assertTrue(a == b, "op_==: a == b")
    assertTrue(not (a == c), "op_==: a != c")
}

@test
func test_unicode_op(): void {
    let result = 1 ⌛ 2
    assertTrue(result == 3, "op_⌛: 1 ⌛ 2 == 3")
}

@test
func main(): void {
    test_op_add()
    test_op_sub()
    test_op_mul()
    test_op_eq()
    test_unicode_op()
}
