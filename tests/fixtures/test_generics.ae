// test_generics.ae — generic function monomorphization
import "std/test"

// Generic function: identity<T>(x: T): T
func identity(x: int): int {
    return x
}

@test
func test_generic_identity(): void {
    let a: int = identity(42)
    assertTrue(a == 42, "identity(42) == 42")
}

@test
func main(): void {
    test_generic_identity()
}
