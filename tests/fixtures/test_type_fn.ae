// test_type_fn.ae — comprehensive function pointer type tests
// Tests: func type syntax, various parameter/return type combinations
import "std/test"

@test
func main(): void {
    // Basic function pointer type: no params, no return
    let f1: func(): void = 0
    let v1: u64 = f1 as u64
    assertEquals(0, v1, "func(): void type")

    // Function pointer with one param
    let f2: func(u64): void = 0
    let v2: u64 = f2 as u64
    assertEquals(0, v2, "func(u64): void type")

    // Function pointer with return type
    let f3: func(): u64 = 0
    let v3: u64 = f3 as u64
    assertEquals(0, v3, "func(): u64 type")

    // Function pointer with params and return
    let f4: func(u64): u64 = 0
    let v4: u64 = f4 as u64
    assertEquals(0, v4, "func(u64): u64 type")

    // Function pointer with multiple params
    let f5: func(u64, u64): u64 = 0
    let v5: u64 = f5 as u64
    assertEquals(0, v5, "func(u64, u64): u64 type")

    // Function pointer with string param
    let f6: func(string): void = 0
    let v6: u64 = f6 as u64
    assertEquals(0, v6, "func(string): void type")

    // Function pointer with bool return
    let f7: func(u64): bool = 0
    let v7: u64 = f7 as u64
    assertEquals(0, v7, "func(u64): bool type")

    // Function pointer with u8 param
    let f8: func(u8): void = 0
    let v8: u64 = f8 as u64
    assertEquals(0, v8, "func(u8): void type")
}
