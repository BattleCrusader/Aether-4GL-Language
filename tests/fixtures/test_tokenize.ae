import "aether"

func main(): u64 {
    let input: string = "hello\n"
    var lexer: Lexer = lexerCreate(input)
    let tokens: [Token] = lexerTokenize(ref lexer)
    var i: u64 = 0
    while i < #tokens {
        let t: Token = tokens[i]
        print("token[" + string(i) + "] kind=" + string(t.kind) + " text='" + t.text + "'\n")
        i++
    }
    return 0
}
