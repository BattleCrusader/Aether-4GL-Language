// test_dyn.ae — dynamic dispatch with dyn Trait
import "std/test"

trait Drawable {
    func draw(self)
}

struct Circle {
    radius: int
}

impl Drawable for Circle {
    func draw(self) {
        print("circle\n")
    }
}

struct Square {
    size: int
}

impl Drawable for Square {
    func draw(self) {
        print("square\n")
    }
}

@test
func test_trait_vtable(): void {
    // Verify vtable structs and instances compile
    assertTrue(true, "trait and impl compiled")
}

@test
func test_multiple_impls(): void {
    // Verify multiple impl blocks for the same trait compile
    assertTrue(true, "multiple impls work")
}
