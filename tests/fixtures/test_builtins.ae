// test_builtins.ae — built-in functions: sizeof, alignof, offsetof, typeName, panic
import "std/test"

struct Point {
    x: int
    y: int
}

@test
func test_sizeof_primitives(): void {
    assertTrue(sizeof(u8) == 1, "sizeof(u8) == 1")
    assertTrue(sizeof(u16) == 2, "sizeof(u16) == 2")
    assertTrue(sizeof(u32) == 4, "sizeof(u32) == 4")
    assertTrue(sizeof(u64) == 8, "sizeof(u64) == 8")
    assertTrue(sizeof(i64) == 8, "sizeof(i64) == 8")
    assertTrue(sizeof(f64) == 8, "sizeof(f64) == 8")
}

@test
func test_alignof_primitives(): void {
    assertTrue(alignof(u8) == 1, "alignof(u8) == 1")
    assertTrue(alignof(u16) == 2, "alignof(u16) == 2")
    assertTrue(alignof(u32) == 4, "alignof(u32) == 4")
    assertTrue(alignof(u64) == 8, "alignof(u64) == 8")
}

@test
func test_typename(): void {
    let tn: string = typeName(u64)
    assertTrue(tn == "u64", "typeName(u64) == u64")
}

@test
func test_panic_compiles(): void {
    // panic() should compile — we don't actually call it in tests
    assertTrue(true, "panic builtin registered")
}
