    c = emitPop(c, "rbp"); c = emitRet(c)
    return c
}

func emitPushBuiltin(c: codegen): codegen {
    c = label(c, "push")
    c = emitPush(c, "rbp"); c = emitMovR64R64(c, "rbp", "rsp")
    c = emitPop(c, "rbp"); c = emitRet(c)
    return c
}

func emitLogicalHelpers(c: codegen): codegen {
    c = label(c, "_logical_true")
    c = emitMovR64Imm64(c, "rax", 1); c = emitRet(c)
    c = label(c, "_logical_false")
    c = emitXorR64R64(c, "rax", "rax"); c = emitRet(c)
    return c
}

func emitStructFieldHelpers(c: codegen): codegen {
    return c
}

// ============================================================
// emitMovR64ToAddr / emitMovFromAddr / emitJnsLabel / emitJbLabel / emitShlR64Imm8
// ============================================================

func emitMovR64ToAddr(c: codegen, src: string, addrReg: string, offset: byte): codegen {
    c = emitRexW(c); c = emitByte(c, 0x89)
    if offset == 0 { c = emitByte(c, modRM(0, regCode(src), regCode(addrReg))) }
    else { c = emitByte(c, modRM(1, regCode(src), regCode(addrReg))); c = emitByte(c, offset) }
    return c
}

func emitMovFromAddr(c: codegen, dst: string, addrReg: string, offset: byte): codegen {
    c = emitRexW(c); c = emitByte(c, 0x8B)
    if offset == 0 { c = emitByte(c, modRM(0, regCode(dst), regCode(addrReg))) }
    else { c = emitByte(c, modRM(1, regCode(dst), regCode(addrReg))); c = emitByte(c, offset) }
    return c
}

func emitJnsLabel(c: codegen, labelName: string): codegen {
    c = emitByte(c, 0x0F); c = emitByte(c, 0x89)
    c.labelRefs = push(c.labelRefs, labelName)
    c.labelRefOffsets = push(c.labelRefOffsets, #c.text)
    c.labelRefSizes = push(c.labelRefSizes, 4)
    c = emitU32(c, 0)
    return c
}

func emitJbLabel(c: codegen, labelName: string): codegen {
    c = emitByte(c, 0x0F); c = emitByte(c, 0x82)
    c.labelRefs = push(c.labelRefs, labelName)
    c.labelRefOffsets = push(c.labelRefOffsets, #c.text)
    c.labelRefSizes = push(c.labelRefSizes, 4)
    c = emitU32(c, 0)
    return c
}

func emitShlR64Imm8(c: codegen, reg: string, imm: byte): codegen {
    c = emitRexW(c); c = emitByte(c, 0xC1)
    c = emitByte(c, modRM(3, 4, regCode(reg)))
    c = emitByte(c, imm)
    return c
}
func align(size: u64, alignment: u64): u64 {
    return (size + alignment - 1) & (0 - alignment)
}

func patchLabelRef(buf: [byte], refOffset: u64, refSize: u64, targetOffset: u64): [byte] {
    let instrEnd = refOffset + refSize
    let disp = targetOffset - instrEnd
    buf[refOffset] = disp & 0xFF
    buf[refOffset + 1] = (disp >> 8) & 0xFF
    buf[refOffset + 2] = (disp >> 16) & 0xFF
    buf[refOffset + 3] = (disp >> 24) & 0xFF
    return buf
}

func findLabelOffset(labels: [string], offsets: [u64], name: string): u64 {
    for i in 0..#labels {
        if labels[i] == name {
            return offsets[i]
        }
    }
    return 0
}

func hasLabel(labels: [string], name: string): bool {
    for i in 0..#labels {
        if labels[i] == name {
            return true
        }
    }
    return false
}
func linkElf(c: codegen): codegen {
    // First, patch all label references in the text buffer
    // We need a mutable copy of text to patch
    var patchedText: [byte] = c.text
    for i in 0..#c.labelRefs {
        let refName = c.labelRefs[i]
        let refOffset = c.labelRefOffsets[i]
        let refSize = c.labelRefSizes[i]
        let targetOffset = findLabelOffset(c.labels, c.labelOffsets, refName)
        if not hasLabel(c.labels, refName) and refName != "" {
            c.errors = push(c.errors, "undefined label: " + refName)
        } else {
            patchedText = patchLabelRef(patchedText, refOffset, refSize, targetOffset)
        }
    }

    // Calculate section offsets
    let textOffset: u64 = 0x1000
    let rodataOffset = textOffset + align(#patchedText, 0x1000)
    let dataOffset = rodataOffset + align(#c.rodata, 0x1000)

    // Calculate file offsets
    let textFileOffset: u64 = 0x1000
    let rodataFileOffset = textFileOffset + #patchedText
    let dataFileOffset = rodataFileOffset + #c.rodata

    // Build ELF64 binary
    let headerSize: u64 = 64
    let phdrSize: u64 = 56
    let phdrs: u64 = 3

    let fileSize = headerSize + phdrs * phdrSize + #patchedText + #c.rodata + #c.data
    var buf: [byte] = []
    var offset: u64 = 0

    // Allocate buffer (fill with zeros)
    for i in 0..fileSize {
        buf = push(buf, 0)
    }

    // ELF Header
    // Magic: 0x7f 'E' 'L' 'F'
    buf[0] = 0x7f
    buf[1] = 69  // 'E'
    buf[2] = 76  // 'L'
    buf[3] = 70  // 'F'
    buf[4] = 2   // 64-bit
    buf[5] = 1   // little endian
    buf[6] = 1   // ELF version
    buf[7] = 0   // OS/ABI
    offset = 16

    // e_type = ET_EXEC (2)
    buf[offset] = 2
    buf[offset+1] = 0
    offset = offset + 2

    // e_machine = x86_64 (0x3E)
    buf[offset] = 0x3E
    buf[offset+1] = 0
    offset = offset + 2

    // e_version = 1
    buf[offset] = 1
    buf[offset+1] = 0
    buf[offset+2] = 0
    buf[offset+3] = 0
    offset = offset + 4

    // e_entry = textOffset
    buf[offset] = textOffset & 0xFF
    buf[offset+1] = (textOffset >> 8) & 0xFF
    buf[offset+2] = (textOffset >> 16) & 0xFF
    buf[offset+3] = (textOffset >> 24) & 0xFF
    buf[offset+4] = (textOffset >> 32) & 0xFF
    buf[offset+5] = (textOffset >> 40) & 0xFF
    buf[offset+6] = (textOffset >> 48) & 0xFF
    buf[offset+7] = (textOffset >> 56) & 0xFF
    offset = offset + 8

    // e_phoff = headerSize + phdrs * phdrSize
    let phoff = headerSize + phdrs * phdrSize
    buf[offset] = phoff & 0xFF
    buf[offset+1] = (phoff >> 8) & 0xFF
    buf[offset+2] = (phoff >> 16) & 0xFF
    buf[offset+3] = (phoff >> 24) & 0xFF
    buf[offset+4] = (phoff >> 32) & 0xFF
    buf[offset+5] = (phoff >> 40) & 0xFF
    buf[offset+6] = (phoff >> 48) & 0xFF
    buf[offset+7] = (phoff >> 56) & 0xFF
    offset = offset + 8

    // e_shoff = 0 (no section headers)
    for i in 0..8 {
        buf[offset] = 0
        offset = offset + 1
    }

    // e_flags = 0
    for i in 0..4 {
        buf[offset] = 0
        offset = offset + 1
    }

    // e_ehsize = headerSize
    buf[offset] = headerSize & 0xFF
    buf[offset+1] = (headerSize >> 8) & 0xFF
    offset = offset + 2

    // e_phentsize = phdrSize
    buf[offset] = phdrSize & 0xFF
    buf[offset+1] = (phdrSize >> 8) & 0xFF
    offset = offset + 2

    // e_phnum = phdrs
    buf[offset] = phdrs & 0xFF
    buf[offset+1] = (phdrs >> 8) & 0xFF
    offset = offset + 2

    // e_shentsize = 0
    buf[offset] = 0
    buf[offset+1] = 0
    offset = offset + 2

    // e_shnum = 0
    buf[offset] = 0
    buf[offset+1] = 0
    offset = offset + 2

    // e_shstrndx = 0
    buf[offset] = 0
    buf[offset+1] = 0
    offset = offset + 2

    // Program Header 1: .text (LOAD, RX)
    // p_type = PT_LOAD (1)
    buf[offset] = 1
    buf[offset+1] = 0
    buf[offset+2] = 0
    buf[offset+3] = 0
    offset = offset + 4

    // p_flags = PF_R | PF_W | PF_X (7) — RWX for runtime data writes
    buf[offset] = 7
    buf[offset+1] = 0
    buf[offset+2] = 0
    buf[offset+3] = 0
    offset = offset + 4

    // p_offset = textFileOffset (file offset where .text data starts)
    buf[offset] = textFileOffset & 0xFF
    buf[offset+1] = (textFileOffset >> 8) & 0xFF
    buf[offset+2] = (textFileOffset >> 16) & 0xFF
    buf[offset+3] = (textFileOffset >> 24) & 0xFF
    buf[offset+4] = (textFileOffset >> 32) & 0xFF
    buf[offset+5] = (textFileOffset >> 40) & 0xFF
    buf[offset+6] = (textFileOffset >> 48) & 0xFF
    buf[offset+7] = (textFileOffset >> 56) & 0xFF
    offset = offset + 8

    // p_vaddr = textOffset
    buf[offset] = textOffset & 0xFF
    buf[offset+1] = (textOffset >> 8) & 0xFF
    buf[offset+2] = (textOffset >> 16) & 0xFF
    buf[offset+3] = (textOffset >> 24) & 0xFF
    buf[offset+4] = (textOffset >> 32) & 0xFF
    buf[offset+5] = (textOffset >> 40) & 0xFF
    buf[offset+6] = (textOffset >> 48) & 0xFF
    buf[offset+7] = (textOffset >> 56) & 0xFF
    offset = offset + 8

    // p_paddr = textOffset
    buf[offset] = textOffset & 0xFF
    buf[offset+1] = (textOffset >> 8) & 0xFF
    buf[offset+2] = (textOffset >> 16) & 0xFF
    buf[offset+3] = (textOffset >> 24) & 0xFF
    buf[offset+4] = (textOffset >> 32) & 0xFF
    buf[offset+5] = (textOffset >> 40) & 0xFF
    buf[offset+6] = (textOffset >> 48) & 0xFF
    buf[offset+7] = (textOffset >> 56) & 0xFF
    offset = offset + 8

    // p_filesz = textFileOffset + len(text)
    let textFileSize = textFileOffset + #patchedText
    buf[offset] = textFileSize & 0xFF
    buf[offset+1] = (textFileSize >> 8) & 0xFF
    buf[offset+2] = (textFileSize >> 16) & 0xFF
    buf[offset+3] = (textFileSize >> 24) & 0xFF
    buf[offset+4] = (textFileSize >> 32) & 0xFF
    buf[offset+5] = (textFileSize >> 40) & 0xFF
    buf[offset+6] = (textFileSize >> 48) & 0xFF
    buf[offset+7] = (textFileSize >> 56) & 0xFF
    offset = offset + 8

    // p_memsz = textFileSize
    buf[offset] = textFileSize & 0xFF
    buf[offset+1] = (textFileSize >> 8) & 0xFF
    buf[offset+2] = (textFileSize >> 16) & 0xFF
    buf[offset+3] = (textFileSize >> 24) & 0xFF
    buf[offset+4] = (textFileSize >> 32) & 0xFF
    buf[offset+5] = (textFileSize >> 40) & 0xFF
    buf[offset+6] = (textFileSize >> 48) & 0xFF
    buf[offset+7] = (textFileSize >> 56) & 0xFF
    offset = offset + 8

    // p_align = 0x1000
    buf[offset] = 0
    buf[offset+1] = 0x10
    buf[offset+2] = 0
    buf[offset+3] = 0
    buf[offset+4] = 0
    buf[offset+5] = 0
    buf[offset+6] = 0
    buf[offset+7] = 0
    offset = offset + 8

    // Program Header 2: .rodata (LOAD, R)
    buf[offset] = 1
    buf[offset+1] = 0
    buf[offset+2] = 0
    buf[offset+3] = 0
    offset = offset + 4

    buf[offset] = 4  // PF_R
    buf[offset+1] = 0
    buf[offset+2] = 0
    buf[offset+3] = 0
    offset = offset + 4

    // p_offset = rodataFileOffset
    buf[offset] = rodataFileOffset & 0xFF
    buf[offset+1] = (rodataFileOffset >> 8) & 0xFF
    buf[offset+2] = (rodataFileOffset >> 16) & 0xFF
    buf[offset+3] = (rodataFileOffset >> 24) & 0xFF
    buf[offset+4] = (rodataFileOffset >> 32) & 0xFF
    buf[offset+5] = (rodataFileOffset >> 40) & 0xFF
    buf[offset+6] = (rodataFileOffset >> 48) & 0xFF
    buf[offset+7] = (rodataFileOffset >> 56) & 0xFF
    offset = offset + 8

    // p_vaddr = rodataOffset
    buf[offset] = rodataOffset & 0xFF
    buf[offset+1] = (rodataOffset >> 8) & 0xFF
    buf[offset+2] = (rodataOffset >> 16) & 0xFF
    buf[offset+3] = (rodataOffset >> 24) & 0xFF
    buf[offset+4] = (rodataOffset >> 32) & 0xFF
    buf[offset+5] = (rodataOffset >> 40) & 0xFF
    buf[offset+6] = (rodataOffset >> 48) & 0xFF
    buf[offset+7] = (rodataOffset >> 56) & 0xFF
    offset = offset + 8

    // p_paddr = rodataOffset
    buf[offset] = rodataOffset & 0xFF
    buf[offset+1] = (rodataOffset >> 8) & 0xFF
    buf[offset+2] = (rodataOffset >> 16) & 0xFF
    buf[offset+3] = (rodataOffset >> 24) & 0xFF
    buf[offset+4] = (rodataOffset >> 32) & 0xFF
    buf[offset+5] = (rodataOffset >> 40) & 0xFF
    buf[offset+6] = (rodataOffset >> 48) & 0xFF
    buf[offset+7] = (rodataOffset >> 56) & 0xFF
    offset = offset + 8

    // p_filesz = len(rodata)
    let rodataLen = #c.rodata
    buf[offset] = rodataLen & 0xFF
    buf[offset+1] = (rodataLen >> 8) & 0xFF
    buf[offset+2] = (rodataLen >> 16) & 0xFF
    buf[offset+3] = (rodataLen >> 24) & 0xFF
    buf[offset+4] = (rodataLen >> 32) & 0xFF
    buf[offset+5] = (rodataLen >> 40) & 0xFF
    buf[offset+6] = (rodataLen >> 48) & 0xFF
    buf[offset+7] = (rodataLen >> 56) & 0xFF
    offset = offset + 8

    // p_memsz = len(rodata)
    buf[offset] = rodataLen & 0xFF
    buf[offset+1] = (rodataLen >> 8) & 0xFF
    buf[offset+2] = (rodataLen >> 16) & 0xFF
    buf[offset+3] = (rodataLen >> 24) & 0xFF
    buf[offset+4] = (rodataLen >> 32) & 0xFF
    buf[offset+5] = (rodataLen >> 40) & 0xFF
    buf[offset+6] = (rodataLen >> 48) & 0xFF
    buf[offset+7] = (rodataLen >> 56) & 0xFF
    offset = offset + 8

    // p_align = 0x1000
    buf[offset] = 0
    buf[offset+1] = 0x10
    buf[offset+2] = 0
    buf[offset+3] = 0
    buf[offset+4] = 0
    buf[offset+5] = 0
    buf[offset+6] = 0
    buf[offset+7] = 0
    offset = offset + 8

    // Program Header 3: .data + .bss (LOAD, RW)
    buf[offset] = 1
    buf[offset+1] = 0
    buf[offset+2] = 0
    buf[offset+3] = 0
    offset = offset + 4

    buf[offset] = 6  // PF_R | PF_W
    buf[offset+1] = 0
    buf[offset+2] = 0
    buf[offset+3] = 0
    offset = offset + 4

    // p_offset = dataFileOffset
    buf[offset] = dataFileOffset & 0xFF
    buf[offset+1] = (dataFileOffset >> 8) & 0xFF
    buf[offset+2] = (dataFileOffset >> 16) & 0xFF
    buf[offset+3] = (dataFileOffset >> 24) & 0xFF
    buf[offset+4] = (dataFileOffset >> 32) & 0xFF
    buf[offset+5] = (dataFileOffset >> 40) & 0xFF
    buf[offset+6] = (dataFileOffset >> 48) & 0xFF
    buf[offset+7] = (dataFileOffset >> 56) & 0xFF
    offset = offset + 8

    // p_vaddr = dataOffset
    buf[offset] = dataOffset & 0xFF
    buf[offset+1] = (dataOffset >> 8) & 0xFF
    buf[offset+2] = (dataOffset >> 16) & 0xFF
    buf[offset+3] = (dataOffset >> 24) & 0xFF
    buf[offset+4] = (dataOffset >> 32) & 0xFF
    buf[offset+5] = (dataOffset >> 40) & 0xFF
    buf[offset+6] = (dataOffset >> 48) & 0xFF
    buf[offset+7] = (dataOffset >> 56) & 0xFF
    offset = offset + 8

    // p_paddr = dataOffset
    buf[offset] = dataOffset & 0xFF
    buf[offset+1] = (dataOffset >> 8) & 0xFF
    buf[offset+2] = (dataOffset >> 16) & 0xFF
    buf[offset+3] = (dataOffset >> 24) & 0xFF
    buf[offset+4] = (dataOffset >> 32) & 0xFF
    buf[offset+5] = (dataOffset >> 40) & 0xFF
    buf[offset+6] = (dataOffset >> 48) & 0xFF
    buf[offset+7] = (dataOffset >> 56) & 0xFF
    offset = offset + 8

    // p_filesz = len(data)
    let dataLen = #c.data
    buf[offset] = dataLen & 0xFF
    buf[offset+1] = (dataLen >> 8) & 0xFF
    buf[offset+2] = (dataLen >> 16) & 0xFF
    buf[offset+3] = (dataLen >> 24) & 0xFF
    buf[offset+4] = (dataLen >> 32) & 0xFF
    buf[offset+5] = (dataLen >> 40) & 0xFF
    buf[offset+6] = (dataLen >> 48) & 0xFF
    buf[offset+7] = (dataLen >> 56) & 0xFF
    offset = offset + 8

    // p_memsz = len(data) + len(bss)
    let dataMemsz = dataLen + #c.bss
    buf[offset] = dataMemsz & 0xFF
    buf[offset+1] = (dataMemsz >> 8) & 0xFF
    buf[offset+2] = (dataMemsz >> 16) & 0xFF
    buf[offset+3] = (dataMemsz >> 24) & 0xFF
    buf[offset+4] = (dataMemsz >> 32) & 0xFF
    buf[offset+5] = (dataMemsz >> 40) & 0xFF
    buf[offset+6] = (dataMemsz >> 48) & 0xFF
    buf[offset+7] = (dataMemsz >> 56) & 0xFF
    offset = offset + 8

    // p_align = 0x1000
    buf[offset] = 0
    buf[offset+1] = 0x10
    buf[offset+2] = 0
    buf[offset+3] = 0
    buf[offset+4] = 0
    buf[offset+5] = 0
    buf[offset+6] = 0
    buf[offset+7] = 0
    offset = offset + 8

    // Write .text at file offset textFileOffset
    for i in 0..#patchedText {
        buf[textFileOffset + i] = patchedText[i]
    }

    // Write .rodata at file offset rodataFileOffset
    for i in 0..#c.rodata {
        buf[rodataFileOffset + i] = c.rodata[i]
    }

    // Write .data at file offset dataFileOffset
    for i in 0..#c.data {
        buf[dataFileOffset + i] = c.data[i]
    }

    c.output = buf
    return c
}

// ============================================================
// Mach-O 64 Linker
// ============================================================

func linkMachO(c: codegen): codegen {
    // First, patch all label references in the text buffer
    // Labels in __TEXT use text offsets, labels in __DATA use data offsets
    // We need to convert file offsets to virtual addresses for correct RIP-relative displacement
    var patchedText: [byte] = c.text
    for i in 0..#c.labelRefs {
        let refName = c.labelRefs[i]
        let refOffset = c.labelRefOffsets[i]
        let refSize = c.labelRefSizes[i]
        let targetOffset = findLabelOffset(c.labels, c.labelOffsets, refName)
        if not hasLabel(c.labels, refName) and refName != "" {
            c.errors = push(c.errors, "undefined label: " + refName)
        } else {
            patchedText = patchLabelRef(patchedText, refOffset, refSize, targetOffset)
        }
    }

    // Combine text + rodata into __TEXT section
    var textSection: [byte] = patchedText
    for i in 0..#c.rodata { textSection = push(textSection, c.rodata[i]) }

    let textSize = #textSection
    let dataSize = #c.data

    // Mach-O header + load commands = 624 bytes
    let headerSize: u64 = 32
    let pagezeroSize: u64 = 72
    let textSegSize: u64 = 144
    let dataSegSize: u64 = 144
    let threadSize: u64 = 184
    let dyldSize: u64 = 48
    let loadCommandsSize = pagezeroSize + textSegSize + dataSegSize + threadSize + dyldSize
    let totalHeaderSize = headerSize + loadCommandsSize

    // File offsets
    let textFileOff: u64 = totalHeaderSize
    let dataFileOff = textFileOff + textSize

    // Virtual addresses (contiguous)
    let textVMAddr: u64 = 0x100000000
    let dataVMAddr = textVMAddr + textSize

    // Re-patch label references using virtual addresses instead of file offsets
    // The displacement for a RIP-relative reference at text offset X to a target at
    // file offset Y is: targetVMAddr - (refVMAddr + refSize)
    // where refVMAddr = textVMAddr + refOffset (since all refs are in __TEXT)
    // and targetVMAddr = textVMAddr + targetOffset if target is in __TEXT
    // or targetVMAddr = dataVMAddr + (targetOffset - textSize - rodataSize) if target is in __DATA
    let rodataSize = #c.rodata
    var patchedText2: [byte] = textSection
    for i in 0..#c.labelRefs {
        let refName = c.labelRefs[i]
        let refOffset = c.labelRefOffsets[i]
        let refSize = c.labelRefSizes[i]
        let targetOffset = findLabelOffset(c.labels, c.labelOffsets, refName)
        if not hasLabel(c.labels, refName) and refName != "" {
            c.errors = push(c.errors, "undefined label: " + refName)
        } else {
            // Convert to virtual addresses
            let refVMAddr = textVMAddr + refOffset
            var targetVMAddr: u64 = 0
            if targetOffset < textSize {
                // Target is in __TEXT
                targetVMAddr = textVMAddr + targetOffset
            } else {
                // Target is in __DATA
                let dataOffset = targetOffset - textSize
                targetVMAddr = dataVMAddr + dataOffset
            }
            let disp = targetVMAddr - (refVMAddr + refSize)
            patchedText2[refOffset] = disp & 0xFF
            patchedText2[refOffset + 1] = (disp >> 8) & 0xFF
            patchedText2[refOffset + 2] = (disp >> 16) & 0xFF
            patchedText2[refOffset + 3] = (disp >> 24) & 0xFF
        }
    }

    let totalFileSize = totalHeaderSize + textSize + dataSize
    var buf: [byte] = []
    for i in 0..totalFileSize { buf = push(buf, 0) }

    var off: u64 = 0

    // Mach-O Header (32 bytes)
    buf[off] = 0xCF; off = off + 1
    buf[off] = 0xFA; off = off + 1
    buf[off] = 0xED; off = off + 1
    buf[off] = 0xFE; off = off + 1
    buf[off] = 0x07; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x01; off = off + 1
    buf[off] = 0x03; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x02; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x05; off = off + 1  // ncmds = 5
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = loadCommandsSize & 0xFF; off = off + 1
    buf[off] = (loadCommandsSize >> 8) & 0xFF; off = off + 1
    buf[off] = (loadCommandsSize >> 16) & 0xFF; off = off + 1
    buf[off] = (loadCommandsSize >> 24) & 0xFF; off = off + 1
    buf[off] = 0x85; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x20; off = off + 1
    buf[off] = 0x00; off = off + 1
    for i in 0..4 { buf[off] = 0; off = off + 1 }

    // LC_SEGMENT_64 __PAGEZERO (72 bytes)
    buf[off] = 0x19; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x48; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x50; off = off + 1
    buf[off] = 0x41; off = off + 1
    buf[off] = 0x47; off = off + 1
    buf[off] = 0x45; off = off + 1
    buf[off] = 0x5A; off = off + 1
    buf[off] = 0x45; off = off + 1
    buf[off] = 0x52; off = off + 1
    buf[off] = 0x4F; off = off + 1
    for i in 0..6 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x01; off = off + 1
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..4 { buf[off] = 0; off = off + 1 }
    for i in 0..4 { buf[off] = 0; off = off + 1 }
    for i in 0..4 { buf[off] = 0; off = off + 1 }
    for i in 0..4 { buf[off] = 0; off = off + 1 }

    // LC_SEGMENT_64 __TEXT (144 bytes) — RX
    buf[off] = 0x19; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x90; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x54; off = off + 1
    buf[off] = 0x45; off = off + 1
    buf[off] = 0x58; off = off + 1
    buf[off] = 0x54; off = off + 1
    for i in 0..10 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = (textVMAddr >> (i * 8)) & 0xFF; off = off + 1 }
    for i in 0..8 { buf[off] = (textSize >> (i * 8)) & 0xFF; off = off + 1 }
    for i in 0..8 { buf[off] = (textFileOff >> (i * 8)) & 0xFF; off = off + 1 }
    for i in 0..8 { buf[off] = (textSize >> (i * 8)) & 0xFF; off = off + 1 }
    buf[off] = 0x05; off = off + 1  // maxprot = RX
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x05; off = off + 1  // initprot = RX
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x01; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    for i in 0..4 { buf[off] = 0; off = off + 1 }
    // Section __text (72 bytes)
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x74; off = off + 1
    buf[off] = 0x65; off = off + 1
    buf[off] = 0x78; off = off + 1
    buf[off] = 0x74; off = off + 1
    for i in 0..10 { buf[off] = 0; off = off + 1 }
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x54; off = off + 1
    buf[off] = 0x45; off = off + 1
    buf[off] = 0x58; off = off + 1
    buf[off] = 0x54; off = off + 1
    for i in 0..10 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = (textVMAddr >> (i * 8)) & 0xFF; off = off + 1 }
    for i in 0..8 { buf[off] = (textSize >> (i * 8)) & 0xFF; off = off + 1 }
    for i in 0..8 { buf[off] = (textFileOff >> (i * 8)) & 0xFF; off = off + 1 }
    for i in 0..4 { buf[off] = 0; off = off + 1 }
    for i in 0..4 { buf[off] = 0; off = off + 1 }
    for i in 0..4 { buf[off] = 0; off = off + 1 }
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x04; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x80; off = off + 1
    for i in 0..8 { buf[off] = 0; off = off + 1 }

    // LC_SEGMENT_64 __DATA (144 bytes) — RW
    buf[off] = 0x19; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x90; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x44; off = off + 1
    buf[off] = 0x41; off = off + 1
    buf[off] = 0x54; off = off + 1
    buf[off] = 0x41; off = off + 1
    for i in 0..10 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = (dataVMAddr >> (i * 8)) & 0xFF; off = off + 1 }
    for i in 0..8 { buf[off] = (dataSize >> (i * 8)) & 0xFF; off = off + 1 }
    for i in 0..8 { buf[off] = (dataFileOff >> (i * 8)) & 0xFF; off = off + 1 }
    for i in 0..8 { buf[off] = (dataSize >> (i * 8)) & 0xFF; off = off + 1 }
    buf[off] = 0x07; off = off + 1  // maxprot = RWX
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x03; off = off + 1  // initprot = RW
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x01; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    for i in 0..4 { buf[off] = 0; off = off + 1 }
    // Section __data (72 bytes)
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x64; off = off + 1
    buf[off] = 0x61; off = off + 1
    buf[off] = 0x74; off = off + 1
    buf[off] = 0x61; off = off + 1
    for i in 0..10 { buf[off] = 0; off = off + 1 }
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x5F; off = off + 1
    buf[off] = 0x44; off = off + 1
    buf[off] = 0x41; off = off + 1
    buf[off] = 0x54; off = off + 1
    buf[off] = 0x41; off = off + 1
    for i in 0..10 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = (dataVMAddr >> (i * 8)) & 0xFF; off = off + 1 }
    for i in 0..8 { buf[off] = (dataSize >> (i * 8)) & 0xFF; off = off + 1 }
    for i in 0..8 { buf[off] = (dataFileOff >> (i * 8)) & 0xFF; off = off + 1 }
    for i in 0..4 { buf[off] = 0; off = off + 1 }
    for i in 0..4 { buf[off] = 0; off = off + 1 }
    for i in 0..4 { buf[off] = 0; off = off + 1 }
    buf[off] = 0x01; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    for i in 0..8 { buf[off] = 0; off = off + 1 }

    // LC_UNIXTHREAD (184 bytes)
    buf[off] = 0x05; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0xB8; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x04; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x2A; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = (textVMAddr >> (i * 8)) & 0xFF; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }
    for i in 0..8 { buf[off] = 0; off = off + 1 }

    // LC_DYLD_INFO_ONLY (48 bytes)
    buf[off] = 0x1B; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x80; off = off + 1
    buf[off] = 0x30; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    buf[off] = 0x00; off = off + 1
    for i in 0..40 { buf[off] = 0; off = off + 1 }

    // Write section data
    for i in 0..#patchedText2 { buf[textFileOff + i] = patchedText2[i] }
    for i in 0..#c.data { buf[dataFileOff + i] = c.data[i] }

    c.output = buf
    return c
}
