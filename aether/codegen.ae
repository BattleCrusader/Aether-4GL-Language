    return c
}

func emitAeArrayNew(c: codegen): codegen {
    c = label(c, "__ae_array_new")
    c = emitPush(c, "rbp"); c = emitMovR64R64(c, "rbp", "rsp")
    c = emitLeaR64Label(c, "rax", "__ae_heap_start")
    c = emitPop(c, "rbp"); c = emitRet(c)
    return c
}

func emitAeStrConcat(c: codegen): codegen {
    c = label(c, "__ae_str_concat")
    c = emitPush(c, "rbp"); c = emitMovR64R64(c, "rbp", "rsp")
    c = emitPop(c, "rbp"); c = emitRet(c)
    return c
}

func emitAeStrEq(c: codegen): codegen {
    c = label(c, "__ae_str_eq")
    c = emitPush(c, "rbp"); c = emitMovR64R64(c, "rbp", "rsp")
    c = emitPush(c, "rbx"); c = emitPush(c, "r12")
    c = emitMovR64R64(c, "rbx", "rdi"); c = emitMovR64R64(c, "r12", "rsi")
    c = label(c, "__ae_str_eq_loop")
    c = emitByte(c, 0x8A); c = emitByte(c, 0x03)
    c = emitByte(c, 0x8A); c = emitByte(c, 0x1C); c = emitByte(c, 0x24); c = emitByte(c, 0x0C); c = emitByte(c, 0x12)
    c = emitCmpR64R64(c, "rax", "rbx")
    c = emitJnzLabel(c, "__ae_str_eq_done")
    c = emitTestR64R64(c, "rax", "rax")
    c = emitJzLabel(c, "__ae_str_eq_done")
    c = emitAddR64Imm8(c, "rbx", 1); c = emitAddR64Imm8(c, "r12", 1)
    c = emitJmpLabel(c, "__ae_str_eq_loop")
    c = label(c, "__ae_str_eq_done")
    c = emitSete(c, "al"); c = emitMovzxR64R8(c, "rax", "al")
    c = emitPop(c, "r12"); c = emitPop(c, "rbx"); c = emitPop(c, "rbp"); c = emitRet(c)
    return c
}

func emitAePush(c: codegen): codegen {
    c = label(c, "__ae_push")
    c = emitPush(c, "rbp"); c = emitMovR64R64(c, "rbp", "rsp")
    c = emitPop(c, "rbp"); c = emitRet(c)
    return c
}

func emitAePop(c: codegen): codegen {
    c = label(c, "__ae_pop")
